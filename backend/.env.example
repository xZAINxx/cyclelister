# --- Application ---
APP_ENV=development

# --- Database ---
# Local dev (docker compose -f docker-compose.dev.yml up -d):
DATABASE_URL=postgresql+asyncpg://cyclelister:cyclelister@127.0.0.1:5533/cyclelister
# Production: Supabase Postgres connection string (use the asyncpg driver prefix).
# In development the app will create tables automatically; in production run:
#   alembic upgrade head

# --- Supabase (auth + storage) ---
# Leave SUPABASE_JWT_SECRET empty for local dev: auth is bypassed with a fixed dev user.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Storage ---
# local: images stored under STORAGE_DIR. supabase: stored in the bucket below.
STORAGE_BACKEND=local
STORAGE_DIR=./data/images
STORAGE_BUCKET=listing-images

# --- Anthropic (AI identification + generation) ---
ANTHROPIC_API_KEY=
VISION_MODEL=claude-sonnet-5
TEXT_MODEL=claude-sonnet-5
CLASSIFY_MODEL=claude-haiku-4-5

# --- eBay (Sell APIs, OAuth2) ---
# Create a keyset at developer.ebay.com. Sandbox first (spec §10).
EBAY_ENV=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=
EBAY_MARKETPLACE_ID=EBAY_US
# Fernet key for encrypting OAuth tokens at rest (spec §15). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EBAY_TOKEN_KEY=

# --- Jobs ---
MAX_CONCURRENT_JOBS=3

# --- Weekly digest email (spec §13) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_FROM=
DIGEST_TO=
